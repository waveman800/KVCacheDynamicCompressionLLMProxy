# ==========================================
# KVCache+动态压缩大模型代理服务 - 环境变量配置
# ==========================================

# ------------------------------------------
# OpenAI 协议三要素（必填）
# ------------------------------------------
# API Key - 你的大模型 API 密钥
API_KEY=your-api-key-here

# 目标服务地址 - 任何兼容 OpenAI API 的服务
# 示例：
#   OpenAI: https://api.openai.com/v1
#   Azure: https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   本地服务: http://localhost:8000/v1
TARGET_URL=https://api.openai.com/v1

# 默认模型名称
MODEL=gpt-4o-mini

# ------------------------------------------
# 压缩配置（可选）
# ------------------------------------------
# 是否启用动态压缩
ENABLE_COMPRESSION=true

# Memories 压缩目标 Token 数
MEMORIES_TARGET=1500

# History 压缩目标 Token 数
HISTORY_TARGET=1000

# 历史对话保留轮数（最近 N 轮不压缩）
HISTORY_KEEP_LAST_N=4

# ------------------------------------------
# 动态压缩算法参数（可选）
# ------------------------------------------
# 相似度阈值（0.0-1.0）
# 值越高，压缩越严格，过滤掉更多相似内容
SIMILARITY_THRESHOLD=0.55

# 会话长度限制
SESSION_LEN=8192

# 快速压缩模式（牺牲压缩率换取速度）
USE_FAST_MODE=false

# ------------------------------------------
# 细粒度压缩参数（可选）
# ------------------------------------------
# 压缩粒度级别：
#   full      - 整个记忆项级别压缩（最快，压缩率较低）
#   paragraph - 按段落压缩（推荐，平衡速度和质量）
#   sentence  - 按句子压缩（最慢，压缩率最高）
COMPRESSION_GRANULARITY=paragraph

# 每个记忆最少保留的片段数（防止过度压缩）
MIN_KEEP_SEGMENTS=1

# 重要性评分权重（总和应为1.0）
# 内容重要性权重（内部自动分配：关键词60% + TF-IDF 40%）
CONTENT_IMPORTANCE_WEIGHT=0.7
# 位置权重（开头/结尾更重要）
POSITION_WEIGHT=0.2
# 查询相关性权重
QUERY_WEIGHT=0.1

# ------------------------------------------
# KV Cache 配置（可选）
# ------------------------------------------
# 是否启用 KV Cache
ENABLE_KV_CACHE=true

# KV Cache 最大条目数（默认2000，配合压缩实际内存≈1000条）
KV_CACHE_SIZE=2000

# KV Cache 过期时间（秒）
KV_CACHE_TTL=3600

# ------------------------------------------
# KV Cache 高性价比优化参数（可选）
# ------------------------------------------
# 启用内存压缩（节省50-70%内存，推荐开启）
KV_CACHE_COMPRESSION=true

# 压缩阈值（字节），大于此值才压缩
KV_CACHE_COMPRESSION_THRESHOLD=1024

# 热点数据比例（0-1），这部分常驻内存不被淘汰
KV_CACHE_HOT_RATIO=0.2

# 自适应TTL（根据命中率动态调整过期时间）
KV_CACHE_ADAPTIVE_TTL=true

# 自适应TTL范围
KV_CACHE_MIN_TTL=300
KV_CACHE_MAX_TTL=7200

# ------------------------------------------
# 服务配置（可选）
# ------------------------------------------
# 监听地址
HOST=0.0.0.0

# 监听端口
PORT=8000
