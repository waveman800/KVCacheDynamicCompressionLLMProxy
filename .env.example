# ==========================================
# KVCache+动态压缩大模型代理服务 环境变量配置
# ==========================================

# ------------------------------------------
# 基础配置 (必需)
# ------------------------------------------

# API Key (OpenAI 或自定义后端)
API_KEY=your-api-key-here

# 目标模型服务地址
# OpenAI: https://api.openai.com/v1
# vLLM: http://localhost:8001/v1
# SGLang: http://localhost:8002/v1
# LMDeploy: http://localhost:8003/v1
TARGET_URL=https://api.openai.com/v1

# 后端类型: openai | vllm | sglang | lmdeploy
BACKEND_TYPE=openai

# ------------------------------------------
# 压缩配置 (可选)
# ------------------------------------------
ENABLE_COMPRESSION=true
MEMORIES_TARGET=15000
HISTORY_TARGET=10000
HISTORY_KEEP_LAST_N=10

# ------------------------------------------
# KV Cache 配置 (可选)
# ------------------------------------------
ENABLE_KV_CACHE=true
KV_CACHE_SIZE=1000
KV_CACHE_TTL=3600

# ------------------------------------------
# 后端特定配置 (根据 BACKEND_TYPE 选择)
# ------------------------------------------

# vLLM 配置
VLLM_PREFIX_CACHING=true

# SGLang 配置  
SGLANG_RADIX_CACHE=true

# LMDeploy 配置
LMDEPLOY_CACHE_ENTRIES=1000

# ------------------------------------------
# 本地模型路径 (使用 vLLM/SGLang/LMDeploy 时需要)
# ------------------------------------------
MODEL_PATH=/path/to/your/models

# 模型名称 (仅用于 vLLM/SGLang/LMDeploy)
VLLM_MODEL=llama-2-7b
SGLANG_MODEL=llama-2-7b
LMDEPLOY_MODEL=llama-2-7b

# ------------------------------------------
# 服务配置 (可选)
# ------------------------------------------
HOST=0.0.0.0
PORT=8000

# ------------------------------------------
# 监控配置 (可选)
# ------------------------------------------
GRAFANA_PASSWORD=admin
